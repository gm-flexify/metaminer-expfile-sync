    {
      "parameters": {
        "content": "## Keitaro Live Stats — кожні 15 хв\nВигружає агреговану статистику напряму з Keitaro API (без запису в БД).\n**GET** `/v2/api/v1/keitaro/live-stats?date_from=...&date_to=...&group_by=campaign`\n\ngroup_by: campaign | day | country\nПовертає: clicks, unique_clicks, leads, sales, rejected, revenue, cost, profit",
        "height": 220,
        "width": 780,
        "color": 3
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-560, 880],
      "id": "sticky-kt-live",
      "name": "Sticky KT Live Stats"
    },

    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 0/15 * * * *"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [-560, 1152],
      "id": "schedule-live-15min",
      "name": "Trigger live-stats 15 min"
    },

    {
      "parameters": {
        "url": "=https://metaminer.flexifyai.pro/v2/api/v1/keitaro/live-stats?date_from={{ $now.toFormat('yyyy-MM-dd') }}&date_to={{ $now.toFormat('yyyy-MM-dd') }}&group_by=campaign",
        "options": {
          "response": { "response": { "neverError": true } },
          "timeout": 120000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [-300, 1152],
      "id": "get-kt-live-stats",
      "name": "GET live-stats"
    },

    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            {
              "id": "cond-live-ok",
              "leftValue": "={{ $json.count }}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "gt" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [-40, 1152],
      "id": "if-live-has-rows",
      "name": "If has rows"
    },

    {
      "parameters": {
        "chatId": "8076969558",
        "text": "=❌ *Keitaro Live Stats Error*\n{{ $json.detail || JSON.stringify($json) }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [220, 1232],
      "id": "tg-live-error",
      "name": "Telegram Live Stats Error",
      "credentials": {
        "telegramApi": {
          "id": "LdEYEJzAEXqpis2J",
          "name": "MiniApp FB Upload Report File BOT"
        }
      }
    }

