{
  "name": "ExpFile Sync v2 — FB Import + Keitaro Sync",
  "nodes": [

    {
      "parameters": {
        "content": "## FB Import via Telegram\nВідправ .xlsx або .csv в чат → бот імпортує в БД.\n**POST** `/v2/api/v1/fb/import-report`\n**Відповідь:** campaigns_upserted, insights_upserted, skipped\n\nПісля успішного імпорту автоматично запускається KT sync у фоні\nдля дат з файлу (bg_tasks.py — не потрібен окремий n8n вузол).",
        "height": 240,
        "width": 780,
        "color": 6
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-560, -1320],
      "id": "sticky-fb-import",
      "name": "Sticky FB Import"
    },

    {
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [-560, -1040],
      "id": "tg-trigger",
      "name": "Telegram Trigger",
      "webhookId": "expfile-v2-tg-trigger",
      "credentials": {
        "telegramApi": {
          "id": "LdEYEJzAEXqpis2J",
          "name": "MiniApp FB Upload Report File BOT"
        }
      }
    },

    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            {
              "id": "cond-has-doc",
              "leftValue": "={{ $json.message.document.file_id }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.3,
      "position": [-300, -1040],
      "id": "filter-has-doc",
      "name": "Filter has document"
    },

    {
      "parameters": {
        "resource": "file",
        "operation": "get",
        "fileId": "={{ $json.message.document.file_id }}",
        "download": true,
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [-40, -1040],
      "id": "tg-get-file",
      "name": "Telegram Get File",
      "credentials": {
        "telegramApi": {
          "id": "LdEYEJzAEXqpis2J",
          "name": "MiniApp FB Upload Report File BOT"
        }
      }
    },

    {
      "parameters": {
        "method": "POST",
        "url": "https://metaminer.flexifyai.pro/v2/api/v1/fb/import-report?dry_run=false",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "parameterType": "formBinaryData",
              "name": "file",
              "inputDataFieldName": "data"
            }
          ]
        },
        "options": {
          "response": { "response": { "neverError": true, "fullResponse": true } },
          "timeout": 300000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [220, -1040],
      "id": "post-fb-import",
      "name": "POST FB import-report"
    },

    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            {
              "id": "cond-http-200",
              "leftValue": "={{ $json.statusCode }}",
              "rightValue": 200,
              "operator": { "type": "number", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [480, -1040],
      "id": "if-fb-200",
      "name": "If FB HTTP 200"
    },

    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "=✅ *FB Import OK*\nКампаній: `{{ $json.body.campaigns_upserted }}`\nInsights: `{{ $json.body.insights_upserted }}`\n{{ $json.body.skipped && $json.body.skipped.length > 0 ? '⚠️ Пропущено рядків: ' + $json.body.skipped.length : '' }}\n_KT sync запущено у фоні_",
        "additionalFields": { "parse_mode": "Markdown", "appendAttribution": false }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [740, -1120],
      "id": "tg-reply-ok",
      "name": "Telegram Reply OK",
      "credentials": {
        "telegramApi": {
          "id": "LdEYEJzAEXqpis2J",
          "name": "MiniApp FB Upload Report File BOT"
        }
      }
    },

    {
      "parameters": {
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "=❌ *FB Import Failed* (HTTP {{ $json.statusCode }})\n`{{ $json.body.message || JSON.stringify($json.body) }}`",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [740, -960],
      "id": "tg-reply-err",
      "name": "Telegram Reply Error",
      "credentials": {
        "telegramApi": {
          "id": "LdEYEJzAEXqpis2J",
          "name": "MiniApp FB Upload Report File BOT"
        }
      }
    },


    {
      "parameters": {
        "content": "## Keitaro Sync Logs — кожні 15 хв\nСинхронізує k_clicks_log + k_conversions_log + k_daily_stats.\n**POST** `/v2/api/v1/keitaro/sync-logs`\n\ndate_from = вчора (щоб захопити пізні конверсії)\ndate_to   = сьогодні\n\nКліки синхронізуються по 1 дню щоб уникнути 504 від Keitaro.\nПри завантаженні файлів через бота KT sync також відбувається\nавтоматично у фоні (bg_tasks.py) — без участі цього вузла.",
        "height": 300,
        "width": 780,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-560, -560],
      "id": "sticky-kt-logs",
      "name": "Sticky KT Logs"
    },

    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 0/15 * * * *"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [-560, -224],
      "id": "schedule-kt-15min",
      "name": "Trigger every 15 min"
    },

    {
      "parameters": {
        "method": "POST",
        "url": "https://metaminer.flexifyai.pro/v2/api/v1/keitaro/sync-logs",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"date_from\": \"{{ $now.minus({ days: 1 }).toFormat('yyyy-MM-dd') }}\",\n  \"date_to\": \"{{ $now.toFormat('yyyy-MM-dd') }}\"\n}",
        "options": {
          "response": { "response": { "neverError": true } },
          "timeout": 600000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [-300, -224],
      "id": "post-kt-sync-logs",
      "name": "POST sync-logs"
    },

    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            {
              "id": "cond-kt-success",
              "leftValue": "={{ $json.success }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [-40, -224],
      "id": "if-kt-success",
      "name": "If KT sync success"
    },

    {
      "parameters": {
        "chatId": "8076969558",
        "text": "=❌ *Keitaro Sync Logs Failed*\n{{ $json.message }}\nErrors: {{ $json.errors ? $json.errors.join(', ') : '—' }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [220, -144],
      "id": "tg-kt-error",
      "name": "Telegram KT Sync Error",
      "credentials": {
        "telegramApi": {
          "id": "LdEYEJzAEXqpis2J",
          "name": "MiniApp FB Upload Report File BOT"
        }
      }
    },


    {
      "parameters": {
        "content": "## Keitaro Sync Reference — кожну годину\nОновлює довідники: campaigns, offers, streams,\nnetworks, traffic sources, landings, groups.\n**POST** `/v2/api/v1/keitaro/sync-reference`\n\nМожна запустити вручну (Manual Trigger) для першого налаштування.",
        "height": 220,
        "width": 780,
        "color": 7
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-560, 208],
      "id": "sticky-kt-ref",
      "name": "Sticky KT Reference"
    },

    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 0 0/1 * * *"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [-560, 480],
      "id": "schedule-kt-hourly",
      "name": "Trigger every 1 hour"
    },

    {
      "parameters": {},
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [-560, 608],
      "id": "manual-trigger-ref",
      "name": "Manual Trigger"
    },

    {
      "parameters": {
        "method": "POST",
        "url": "https://metaminer.flexifyai.pro/v2/api/v1/keitaro/sync-reference",
        "options": {
          "response": { "response": { "neverError": true } },
          "timeout": 300000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [-300, 528],
      "id": "post-kt-sync-ref",
      "name": "POST sync-reference"
    },

    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            {
              "id": "cond-ref-success",
              "leftValue": "={{ $json.success }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [-40, 528],
      "id": "if-ref-success",
      "name": "If Reference success"
    },

    {
      "parameters": {
        "chatId": "8076969558",
        "text": "=✅ *Keitaro Reference Synced*\nCampaigns: {{ $json.details.campaigns || 0 }}\nOffers: {{ $json.details.offers || 0 }}\nStreams: {{ $json.details.streams || 0 }}\nNetworks: {{ $json.details.affiliate_networks || 0 }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "type": "n8n-nodes-base.telegram",
